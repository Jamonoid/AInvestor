# ============================================
# AutoInvest - Variables de Entorno
# Copia este archivo a .env y llena los valores
# ============================================

# --- Binance ---
BINANCE_API_KEY=tu_api_key_aqui
BINANCE_API_SECRET=tu_api_secret_aqui

# --- OpenRouter (principal) ---
OPENROUTER_API_KEY=tu_openrouter_key_aqui
OPENROUTER_MODEL=moonshotai/kimi-k2

# --- Google Gemini (fallback, opcional) ---
# GEMINI_API_KEY=tu_gemini_api_key_aqui

# --- LLM Sampling Parameters ---
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_TOP_K=40
LLM_MAX_TOKENS=4096

# --- Modo de Operacion ---
# "paper" = simulado (sin dinero real)
# "live"  = real (CUIDADO)
TRADING_MODE=paper

# --- Capital Inicial para Paper Trading (USD) ---
PAPER_TRADING_BALANCE=10000

# --- Riesgo ---
MAX_POSITION_PERCENT=5
STOP_LOSS_PERCENT=3
TAKE_PROFIT_PERCENT=8
MAX_DAILY_TRADES=10
MAX_DRAWDOWN_PERCENT=15

# --- Trailing Stop ---
TRAILING_STOP_ENABLED=true
TRAILING_STOP_PERCENT=2.0

# --- Simulacion (paper trading) ---
SIMULATED_SLIPPAGE_PERCENT=0.1
SIMULATED_FEES_PERCENT=0.1

# --- Take-Profit Parcial ---
# Cerrar este % de la posicion al primer TP, dejar el resto correr
TAKE_PROFIT_PARTIAL_PERCENT=50

# --- Confianza del Agente ---
# Trades con confianza entre small y normal se ejecutan con max 2% del portfolio
MIN_CONFIDENCE_SMALL=50
MIN_CONFIDENCE_NORMAL=60

# --- Liquidez ---
# Volumen 24h del par debe ser N veces mayor que la orden
MIN_LIQUIDITY_RATIO=10

# --- Dashboard ---
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8888

# --- Discord (opcional, para fase posterior) ---
# DISCORD_WEBHOOK_URL=tu_webhook_aqui
